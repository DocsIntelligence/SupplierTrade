generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════
// NOTE ON "ENUMS"
// ═══════════════════════════════════════════════════════════════════
// SQLite does not support native enums, scalar string lists, or the
// `@db.Decimal(p,s)` native type. The former enum columns are plain
// `String` fields; their allowed values are defined as const objects +
// union types in `@org/utils` (libs/shared/utils/src/lib/enums.ts) and
// shared by both the API and the frontend. Scalar arrays are stored as
// `Json`. Keep the @org/utils enums in sync with the defaults below.

// ═══════════════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════════════

// ─── User ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  username      String    @unique
  picture       String?
  provider      String    @default("email")
  role          String    @default("user")
  emailVerified Boolean   @default(false)
  locale        String    @default("en-US")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  secrets       Secrets?
  identities    UserIdentity[]
  passkeys      Passkey[]
  wallet        UserWallet?
  payments      Payment[]
  notifications Notification[]
  pushSubs      PushSubscription[]
  verifications UserVerification[]

  @@index([email])
}

// ─── Secrets (1:1 with User) ───────────────────────────────────

model Secrets {
  id                   String    @id @default(cuid())
  userId               String    @unique
  password             String?
  refreshToken         String?
  resetToken           String?
  resetTokenExpiresAt  DateTime?
  verificationToken    String?
  lastSignedIn         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── OAuth Identities ──────────────────────────────────────────

model UserIdentity {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

// ─── Passkeys (WebAuthn) ───────────────────────────────────────

model Passkey {
  id           String   @id @default(cuid())
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  deviceType   String?
  backedUp     Boolean  @default(false)
  transports   Json     @default("[]")
  label        String?
  userId       String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Challenge Store (for WebAuthn) ────────────────────────────

model Challenge {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Plans ─────────────────────────────────────────────────────

model Plan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  type            String   @default("one_time")
  duration        Int      @default(1)
  interval        String   @default("monthly")
  price           Int      @default(0)
  originalPrice   Int?
  discountLabel   String?
  priceMultiplier Int      @default(100)
  currency        String   @default("INR")
  active          Boolean  @default(true)
  gatewayPlanId   String?
  totalCycleCount Int?     @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  features PlanFeature[]
  wallets  UserWallet[]
}

model PlanFeature {
  id          String  @id @default(cuid())
  name        String
  action      String  @default("reset")
  quantity    Int     @default(0) // -1 = unlimited
  description String?

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([name, planId])
}

// ─── Wallet ────────────────────────────────────────────────────

model UserWallet {
  id          String   @id @default(cuid())
  paymentType String   @default("one_time")
  active      Boolean  @default(false)
  startAt     DateTime
  endAt       DateTime

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  usage WalletUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletUsage {
  id       String @id @default(cuid())
  name     String
  quantity Int    @default(0) // -1 = unlimited
  consumed Int    @default(0)

  userWalletId String
  wallet       UserWallet @relation(fields: [userWalletId], references: [id], onDelete: Cascade)

  @@unique([name, userWalletId])
}

// ─── Payments ──────────────────────────────────────────────────

model Payment {
  id                    String    @id @default(cuid())
  gateway               String    @default("razorpay")
  gatewayPaymentId      String?   @unique
  gatewayOrderId        String?
  gatewaySubscriptionId String?
  status                String    @default("pending")
  amount                Int?
  currency              String?
  initiatedAt           DateTime?
  confirmedAt           DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  wallets UserWallet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Lookups (configurable dropdowns / reference data) ─────────

model LookupGroup {
  id          String  @id @default(cuid())
  name        String
  key         String  @unique
  description String?
  isPublic    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values LookupValue[]
}

model LookupValue {
  id        String  @id @default(cuid())
  label     String
  value     String?
  order     Int     @default(0)
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)
  metadata  Json?

  groupId String
  group   LookupGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, value])
}

// ─── Mail Queue & Logs ─────────────────────────────────────────

model MailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  template    String?
  body        String?
  status      String   @default("queued") // "queued" | "sent" | "failed"
  attempts    Int      @default(0)
  error       String?
  metadata    Json?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── AI usage metering (generic; nullable trace columns are soft refs) ──
model AiUsage {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  /// When the AI call returned (success or error). Null on still-streaming rows.
  finishedAt DateTime?

  // ── Who ─────────────────────────────────────────────────────────
  /// Acting user (null for system/cron jobs like a backfill reindex).
  userId    String?
  /// Tenant. Denormalised so org-level rollups don't need to join through user.
  orgId     String?
  /// Group N calls in one user "session" (chat conversation, drafting session,
  /// review session). Free-form id minted by the caller.
  sessionId String?

  // ── Trace hierarchy (Langfuse-style) ────────────────────────────
  /// Parent trace id. An "extract" trace might fan out into classify + extract +
  /// critique sub-calls — same `traceId` on all three, with `parentSpanId`
  /// linking children to their parent within the trace.
  traceId      String?
  parentSpanId String?

  // ── What ────────────────────────────────────────────────────────
  /// Logical operation. Keep in sync with `AI_OPERATIONS` in code.
  /// 'classify' | 'extract' | 'critique' | 'generate' | 'revise' | 'analyse'
  /// | 'ask' | 'embed' | 'parse' | 'rerank' | 'moderate' | 'vision' | 'tts'
  /// | 'stt' | 'tool_call'.
  operation   String
  /// Product-feature attribution for per-feature billing dashboards.
  /// 'doc.draft.legal_notice' | 'intel.classify' | 'intel.extract.invoice'
  /// | 'intel.analyse' | 'intel.ask' | 'search.embed' | …
  featureCode String?

  // ── Model identity ─────────────────────────────────────────────
  /// 'openai' | 'anthropic' | 'google' | 'llamaparse' | 'reducto' | …
  provider     String
  /// e.g. 'claude-haiku-4-5-20251001', 'gpt-5o', 'text-embedding-3-small'.
  model        String
  /// Surface-pinned snapshot when the provider exposes one (e.g. dated alias).
  modelVersion String?

  // ── Related entities (any combo set; all indexed) ──────────────
  /// Drafting document (Documents world).
  documentId       String?
  /// Uploaded source (Intelligence world).
  sourceDocumentId String?
  /// Pipeline run (one per uploaded doc through a pipeline).
  pipelineRunId    String?
  /// Extraction record (one per successful extract).
  extractionId     String?
  /// Analysis run (analyse / ask).
  analysisRunId    String?
  /// Batch (groups N pipeline runs from a single multi-file upload).
  batchId          String?

  // ── Token measurements ─────────────────────────────────────────
  inputTokens       Int @default(0)
  outputTokens      Int @default(0)
  /// Anthropic cache-read input tokens (charged at a discount).
  cachedInputTokens Int @default(0)
  /// Anthropic cache-write input tokens (charged at a premium).
  cacheWriteTokens  Int @default(0)
  /// Reasoning / "thinking" tokens (OpenAI o-series, Anthropic extended
  /// thinking, Gemini "thoughts") — separate billing tier on some models.
  reasoningTokens   Int @default(0)
  totalTokens       Int @default(0)

  // ── Alternate billable units (pages, requests, characters, seconds) ──
  /// LlamaParse / Reducto bill per page; image OCR per image; TTS per char.
  /// Use this when `unitType != 'tokens'`. Cost engine multiplies by the
  /// matching pricing row.
  unitsUsed Int    @default(0)
  unitType  String @default("tokens")

  // ── File / payload sizes (debugging, not billing) ──────────────
  inputBytes  Int?
  outputBytes Int?

  // ── Cost ───────────────────────────────────────────────────────
  /// Cost in USD computed at call time from the pricing row in effect.
  estimatedCostUsd Decimal @default(0)
  /// FK into `AiModelPricing.id` so finance can reconcile against the exact
  /// rate-card row that was applied (rate cards change; rows are immutable).
  pricingId        String?

  // ── Latency ────────────────────────────────────────────────────
  durationMs            Int  @default(0)
  /// Time-to-first-token for streaming calls (null for non-streaming).
  latencyToFirstTokenMs Int?
  /// Time spent queued before the request started (provider rate-limit waits).
  queuedMs              Int?

  // ── Outcome ────────────────────────────────────────────────────
  /// 'success' | 'error' | 'timeout' | 'rate_limited' | 'cancelled' | 'partial'.
  status       String  @default("success")
  /// 1 = first try; >1 = retry / fallback to next provider.
  attempt      Int     @default(1)
  /// When this row is a retry of an earlier failed call, link back so the UI
  /// can collapse retry chains under the original attempt.
  retryOfId    String?
  /// Provider's reason for stopping: 'stop' | 'length' | 'tool_calls'
  /// | 'content_filter' | 'error' | 'cancelled'.
  finishReason String?
  errorCode    String?
  errorMessage String?

  // ── Provider request identity (debugging + dedupe) ────────────
  /// Provider's request id (Anthropic `x-request-id`, OpenAI `request-id`).
  requestId      String?
  /// Caller-supplied idempotency key (dedupe identical retries).
  idempotencyKey String?

  // ── Sampling knobs (for reproducibility / cost analysis) ──────
  temperature Float?
  maxTokens   Int?
  /// True when the response was streamed.
  streamed    Boolean @default(false)

  // ── Filtering + retention ─────────────────────────────────────
  /// Free-form labels for search / cost tagging (`feature:invoice`,
  /// `experiment:v2`, `customer:acme`, …). Stored as a JSON array of strings.
  tags          Json     @default("[]")
  /// GDPR / compliance: how long this row should live. A nightly job purges
  /// rows whose `createdAt + retentionDays` is in the past.
  retentionDays Int      @default(365)

  /// Provider-specific extras + caller hints. Keep small (<8 KB) — anything
  /// big belongs as a column or external blob.
  metadata Json?

  // Indexes — one composite per major rollup axis.
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@index([sessionId])
  @@index([traceId])
  @@index([documentId])
  @@index([sourceDocumentId])
  @@index([pipelineRunId])
  @@index([extractionId])
  @@index([analysisRunId])
  @@index([batchId])
  @@index([operation, createdAt])
  @@index([provider, model, createdAt])
  @@index([featureCode, createdAt])
  @@index([status, createdAt])
}

// ── Generic key/scope/value settings store ──
model Setting {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Dotted hierarchical key (e.g. `ai.usage.tracking.enabled`,
  /// `ai.usage.retention.days`, `intelligence.classify.confidence_threshold`).
  key String

  /// 'system' | 'org' | 'user'. Narrower scope wins on lookup.
  scope   String
  /// Required for org/user scope; empty string sentinel for system. Non-null
  /// so the compound unique `(scope, scopeId, key)` enforces "one override
  /// per scope+key".
  scopeId String  @default("")

  /// JSON value — booleans, numbers, strings, arrays, objects all fit here.
  value Json

  /// Optional admin note explaining why the override exists ("disabled for
  /// EU customers", "raised retention to 730d for compliance", …).
  notes String?

  @@unique([scope, scopeId, key])
  @@index([key])
  @@index([scope, scopeId])
}

// ── AI model pricing table (cost reconciliation for AiUsage) ──
model AiModelPricing {
  id           String  @id @default(cuid())
  provider     String
  model        String
  modelVersion String?
  currency     String  @default("USD")

  /// What `unitsUsed` measures for the matching AiUsage rows.
  /// 'tokens' (LLMs) | 'pages' (LlamaParse) | 'characters' (TTS)
  /// | 'requests' (per-call flat) | 'seconds' (STT) | 'images' (vision).
  unitType String @default("tokens")

  // Per-1M-unit rates. Set the lanes that apply for this model; null = N/A.
  inputPer1M       Decimal?
  outputPer1M      Decimal?
  /// Anthropic cache-read input — usually a fraction of inputPer1M.
  cachedInputPer1M Decimal?
  /// Anthropic cache-write input — usually a premium over inputPer1M.
  cacheWritePer1M  Decimal?
  /// Reasoning / thinking tokens (o-series, Anthropic ext-thinking).
  reasoningPer1M   Decimal?
  /// Flat fee per call (overrides per-unit math when set; or stacked on top).
  perCallUsd       Decimal?

  /// Active rate-card validity window. Multiple rows per model are normal
  /// (price history); exactly one is active (`effectiveTo IS NULL`) at a time.
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  active        Boolean   @default(true)
  /// 'official' | 'manual' | 'imported' — provenance for the rate card.
  source        String    @default("manual")
  /// Admin notes — promo discounts, contract pricing, "to validate", …
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, model, active])
  @@index([provider, model, effectiveFrom])
}

// ═══════════════════════════════════════════════════════════════════
// NOTIFICATION + WEB PUSH (generic, boilerplate)
// ═══════════════════════════════════════════════════════════════════

/// In-app notification bell. One row per recipient per event.
/// `type` is a free-form string (e.g. "system", "billing", "verification",
/// "broadcast") — define your project's vocabulary in @org/utils enums.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  /// In-app path to open when tapped.
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

/// One Web Push subscription per device/browser.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  ua        String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════
// VERIFICATION (generic identity / address / kyc)
// ═══════════════════════════════════════════════════════════════════

/// One-time phone or email OTP. Raw code is hashed; only the hash is stored.
/// In dev (no SMS provider) the code is written to the server log.
model PhoneOtp {
  id         String    @id @default(cuid())
  /// Phone (E.164) or email address — the target of the OTP.
  target     String
  channel    String    @default("sms") // sms | email
  codeHash   String
  /// `verify_phone` | `verify_email` | `login` | `reset_password` etc.
  purpose    String    @default("verify_phone")
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([target, purpose])
}

/// Generic user-level verification record. Replace Matrimonial's
/// Profile-bound verification with a User-bound one. `kind` is free-form
/// (e.g. "identity", "address", "email", "phone", "kyc"); kind-specific
/// fields live inside `payload` JSON. `evidenceKey` is a storage object key
/// — purge after decision per retention policy.
model UserVerification {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         String
  status       String    @default("pending") // pending | auto_passed | auto_failed | approved | rejected
  payload      Json?
  evidenceKey  String?
  providerRef  String?
  reviewedBy   String?
  decidedAt    DateTime?
  rejectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, kind])
  @@index([status])
}
