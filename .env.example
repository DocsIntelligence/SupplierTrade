# ═══════════════════════════════════════════════════════════════════════════════
# @org/starter — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in ALL required values.
# Required fields have no default — the app will NOT start without them.
# Optional fields are marked (optional) — features are disabled if missing.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App (REQUIRED) ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
GLOBAL_PREFIX=api
PUBLIC_URL=http://localhost:3000
# Where the API redirects to after OAuth completes (the React dashboard).
FRONTEND_URL=http://localhost:4200
CORS_ORIGIN=http://localhost:4200,http://localhost:4300
LOG_LEVEL=info

# ─── Cookies (REQUIRED) ─────────────────────────────────────────────────────
# Production: COOKIE_DOMAIN=.yourdomain.com  COOKIE_SECURE=true
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ─── JWT (REQUIRED) ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_TTL=7d

# ─── Database (REQUIRED) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter?schema=public

# ─── OAuth: Google (optional) ───────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── OAuth: GitHub (optional) ───────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# ─── OAuth: LinkedIn (optional) ─────────────────────────────────────────────
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback

# ─── Mail / SMTP (optional) ─────────────────────────────────────────────────
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@example.com

# ─── Payment: Razorpay (optional) ───────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ─── Payment: Stripe (optional) ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ─── React App (apps/app) — Vite ─────────────────────────────────────────────
# VITE_API_URL=http://localhost:3000/api
# VITE_APP_URL=http://localhost:4200
# VITE_RAZORPAY_KEY_ID=

# ─── Next.js App (apps/web) ──────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# NEXT_PUBLIC_WEB_URL=http://localhost:4300
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
