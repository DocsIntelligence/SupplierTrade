# ═══════════════════════════════════════════════════════════════════════════════
# @org/starter — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# For production, ensure all required fields are set and secrets are strong.
#
# Architecture:
#   xyz.com           → Next.js (web) — landing pages, SEO
#   api.xyz.com       → NestJS (api) — backend
#   dashboard.xyz.com → React (app) — dashboard, behind login
#
# Auth is shared across subdomains via httpOnly cookies on the root domain.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
GLOBAL_PREFIX=api
LOG_LEVEL=info

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (all subdomains that call the API)
# Development:
CORS_ORIGIN=http://localhost:4200,http://localhost:4300,http://localhost:3000
# Production:
# CORS_ORIGIN=https://xyz.com,https://dashboard.xyz.com

# ─── Cookies (cross-subdomain auth) ─────────────────────────────────────────
# Root domain for cookies — all subdomains will share auth
# Development: use "localhost" (no dot prefix needed)
# Production: use ".xyz.com" (dot prefix = all subdomains)
COOKIE_DOMAIN=localhost
# Set to "true" in production (requires HTTPS)
COOKIE_SECURE=false

# ─── JWT / Auth Tokens ───────────────────────────────────────────────────────
# IMPORTANT: In production, use 32+ character random strings.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Access and refresh secrets MUST be different.
ACCESS_TOKEN_SECRET=dev-access-secret-change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me-in-production
REFRESH_TOKEN_TTL=7d

# ─── Database ────────────────────────────────────────────────────────────────
# Required in production. Supports PostgreSQL, MySQL, SQLite connection strings.
# For local development with SQLite:
DATABASE_URL=file:./tools/prisma/dev.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb?schema=public

# ─── OAuth: Google ───────────────────────────────────────────────────────────
# All three must be set together, or none.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── Mail / SMTP ─────────────────────────────────────────────────────────────
# Required for password reset and email verification features.
# MAIL_HOST, MAIL_PORT, and MAIL_FROM must all be set if any is provided.
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@xyz.com

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ─── React App (apps/app) — Vite ─────────────────────────────────────────────
# VITE_API_URL=http://localhost:3000/api
# Production: VITE_API_URL=https://api.xyz.com/api

# ─── Next.js App (apps/web) ──────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# Production: NEXT_PUBLIC_API_URL=https://api.xyz.com/api
