# API-specific env (loaded by NestJS ConfigModule)
# See root .env.example for full documentation.

NODE_ENV=development
PORT=7130
GLOBAL_PREFIX=api
LOG_LEVEL=info

CORS_ORIGIN=http://localhost:7100,http://localhost:7110,http://localhost:7130

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

ACCESS_TOKEN_SECRET=dev-access-secret-change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me-in-production
REFRESH_TOKEN_TTL=7d

