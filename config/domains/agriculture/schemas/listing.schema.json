{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agriculture/listing.schema.json",
  "title": "Agriculture listing (produce lot) attributes",
  "type": "object",
  "additionalProperties": false,
  "required": ["commodity", "quantity_mt"],
  "properties": {
    "commodity": {
      "type": "string",
      "title": "Commodity",
      "x-widget": "select",
      "x-lookup": "agri-commodities"
    },
    "variety": {
      "type": "string",
      "title": "Variety / grade name"
    },
    "quantity_mt": {
      "type": "number",
      "title": "Quantity (metric tonnes)",
      "exclusiveMinimum": 0
    },
    "price_per_quintal_inr": {
      "type": "number",
      "title": "Asking price (INR / quintal)",
      "minimum": 0
    },
    "harvest_month": {
      "type": "string",
      "title": "Harvest month (YYYY-MM)",
      "pattern": "^[0-9]{4}-[0-9]{2}$"
    },
    "moisture_pct": {
      "type": "number",
      "title": "Self-declared moisture %",
      "minimum": 0,
      "maximum": 100
    }
  }
}
