{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "importHelpers": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/api/*": ["apps/api/src/*"],
      "@/app/*": ["apps/app/src/*"],
      "@/web/*": ["apps/web/src/*"],
      "@org/dto": ["libs/shared/dto/src/index.ts"],
      "@org/utils": ["libs/shared/utils/src/index.ts"],
      "@org/api-client": ["libs/shared/api-client/src/index.ts"],
      "@org/ui": ["libs/shared/ui/src/index.ts"],
      "@org/hooks": ["libs/shared/hooks/src/index.ts"],
      "@org/store": ["libs/shared/store/src/index.ts"],
      "@org/transliteration": ["libs/shared/transliteration/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "tmp", ".nx"]
}
